# ─────────────────────────────────────────────────────────────────────────────
# Vedic Astrology RAG Portal — environment variable reference
#
# Copy to `.env` and fill in as needed:   cp .env.example .env
# Every value is OPTIONAL; the defaults shown work for a local single-host setup.
#
# IMPORTANT: the app reads from the *process environment* — it does NOT auto-load
# this file. Load it before launching, e.g.:
#     set -a && source .env && set +a && python3 app.py
# or, for systemd, point the unit at it:   EnvironmentFile=/path/to/.env
# `.env` is gitignored; this `.env.example` is the committed template.
# ─────────────────────────────────────────────────────────────────────────────

# ── Paths ────────────────────────────────────────────────────────────────────
# SQLite database (defaults to ./vedic_astrology_rag.db next to app.py).
#VEDIC_DB_PATH=/home/prasanth/Vedic_Rag/vedic_astrology_rag.db
# Folder holding the source PDF books for OCR ingest / page-image rendering
# (defaults to ./books next to app.py).
#VEDIC_BOOKS_DIR=/path/to/vedic_astrology_books
# Swiss Ephemeris data dir (the se*.se1 files). Defaults to ./ephe next to
# app.py; if absent the engine falls back to the lower-accuracy Moshier model.
#VEDIC_EPHE_PATH=/usr/share/ephe
# System font dir searched (after the bundled ./fonts dir) for the Noto faces
# used to render Indic-language PDFs. Defaults to /usr/share/fonts/truetype/noto.
#VEDIC_FONT_DIR=/usr/share/fonts/truetype/noto
# Worker threads for the OCR ingest job (defaults to the host CPU count).
#VEDIC_INGEST_THREADS=4
# Log verbosity: DEBUG / INFO / WARNING / ERROR (default INFO).
#VEDIC_LOG_LEVEL=INFO

# ── OpenRouter backend (LLM chat + RAG embeddings via the OpenAI SDK) ────────
# REQUIRED for all AI/embedding endpoints. Keep the real key out of git.
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional attribution headers used by OpenRouter rankings:
#OPENROUTER_REFERER=https://vedicastroai.net
#OPENROUTER_TITLE=Vedic Astrology AI RAG Portal

# ── Models (OpenRouter model IDs) ────────────────────────────────────────────
MODEL_FAST=deepseek/deepseek-v4-flash
MODEL_BALANCED=google/gemma-4-31b-it
MODEL_PREMIUM=deepseek/deepseek-v4-pro
# RAG embedding model — text-embedding-3-small is 1536-dim. CHANGING THIS
# REQUIRES re-ingesting the corpus (python3 ingest.py) so stored vectors match.
MODEL_EMBEDDING=openai/text-embedding-3-small

# The single LLM all AI endpoints use (backend-enforced). Defaults to MODEL_BALANCED.
#VEDIC_LLM_MODEL=google/gemma-4-31b-it
# Must match the embedding model's output dimension (text-embedding-3-small=1536).
#VEDIC_EMBED_DIM=1536

# ── Timeouts (seconds) ───────────────────────────────────────────────────────
#VEDIC_EMBED_TIMEOUT=30
#VEDIC_LLM_TIMEOUT=300

# ── Operator API key (gates ONLY the corpus/admin endpoints) ─────────────────
# Gates /api/search, /api/page-*, /api/status, /api/books — the OCR'd corpus.
# The rest of /api is open or session-gated, so ordinary visitors are never
# prompted for a key. If unset, a key is auto-generated and saved to `.api_key`
# (printed once to the console on first run). Set this to pin a stable key.
#VEDIC_API_KEY=replace-with-a-long-random-secret
# Set to 0 to drop the operator key entirely (corpus endpoints become public).
#VEDIC_REQUIRE_API_KEY=1

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins, or "*" (default). Set to your real front-end
# origin in production; credentials turn on automatically once it isn't "*".
# For the Capacitor Android app also include capacitor://localhost and https://localhost.
#VEDIC_CORS_ORIGINS=https://astro.example.com
#VEDIC_CORS_ORIGINS=https://vedicastroai.net,capacitor://localhost,https://localhost

# ── Credit / billing ─────────────────────────────────────────────────────────
# Emails (comma-separated, case-insensitive) that bypass credit metering.
#VEDIC_UNLIMITED_EMAILS=admin@example.com
# Razorpay is the live payment gateway (UPI/cards, INR). Set all three to enable
# real checkout: create-order builds a Razorpay Order, verify-payment validates
# the signed callback, and the webhook (HMAC-verified) authoritatively grants
# credits. Unset -> payments fail closed (503).
#RAZORPAY_KEY_ID=rzp_live_xxx
#RAZORPAY_KEY_SECRET=xxxxxxxx
#RAZORPAY_WEBHOOK_SECRET=xxxxxxxx
# GST on digital services (18%). Pack prices are GST-INCLUSIVE.
#VEDIC_GST_RATE=0.18
# Astro Pass recurring subscription (Razorpay Subscriptions). Create a ₹99/mo
# Plan in the Razorpay dashboard and put its id here; create-subscription fails
# closed (503) without it. The rest are tunables for cycles/refill/period.
#RAZORPAY_PLAN_ID=plan_xxxxxxxx
#VEDIC_SUBSCRIPTION_TOTAL_COUNT=120
#VEDIC_SUBSCRIPTION_PRICE_PAISE=9900
#VEDIC_SUBSCRIPTION_REFILL_CREDITS=5000
#VEDIC_SUBSCRIPTION_PERIOD_DAYS=30
# Local-dev only: instant credit grant without a real charge (buy-credits).
#VEDIC_ALLOW_SIMULATED_PAYMENTS=0
# Reserved hook for a future international/card path (not yet implemented).
#STRIPE_SECRET_KEY=sk_live_xxx

# ── Growth & safeguards (Phase 4) ────────────────────────────────────────────
# Per-user LLM-action rate limit (calls / 60s; 0 disables). 429 on breach.
#VEDIC_RATE_LIMIT_AI_PER_MIN=15
# Soft monthly ceiling on a subscriber's LLM calls (logged, not blocked).
#VEDIC_SUBSCRIPTION_SOFT_CAP=150
# Referral rewards (credits) for the new user and the referrer, per signup.
#VEDIC_REFERRAL_BONUS_REFEREE=50
#VEDIC_REFERRAL_BONUS_REFERRER=25
# Conversation turns kept in the AI-chat prompt (caps prompt-token growth).
#VEDIC_CHAT_HISTORY_TURNS=3

# ── OAuth / social login ─────────────────────────────────────────────────────
# Identity is taken only from a provider-verified token; unconfigured providers
# fail closed. Set these to enable real Google sign-in.
#GOOGLE_OAUTH_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# ── OTP / SMS Login (MSG91) ──────────────────────────────────────────────────
# Configure MSG91 to enable SMS OTP delivery (SMS-only). Fails closed if unset.
#MSG91_AUTH_KEY=your_msg91_auth_key_here
#MSG91_OTP_TEMPLATE_ID=your_otp_template_id_here

# Dev-only: trust the supplied email/phone (cannot take over password/other-provider
# accounts). If no real SMS API is configured, the OTP is printed to the
# console, and if VEDIC_ALLOW_MOCK_OAUTH=1, it is returned in the API response.
# NEVER enable in production.
#VEDIC_ALLOW_MOCK_OAUTH=0

# ── Public base URL & SEO pages ──────────────────────────────────────────────
# Absolute origin used in shareable chart links, the sitemap, and digest
# emails. Set to the real deployed origin in production.
#VEDIC_PORTAL_BASE_URL=https://vedicastroai.net

# ── Daily digest email (tools/send_digests.py, cron-invoked) ────────────────
# SMTP relay for the opt-in daily panchangam/transit digest. Fails closed:
# with no host configured the sender logs and exits. Port 465 = implicit TLS,
# anything else attempts STARTTLS.
#VEDIC_SMTP_HOST=smtp.example.com
#VEDIC_SMTP_PORT=587
#VEDIC_SMTP_USER=digest@example.com
#VEDIC_SMTP_PASSWORD=xxxx
#VEDIC_SMTP_FROM=digest@example.com
# Astro Pass subscribers get their digest rewritten once by MODEL_FAST
# (deterministic text is the fallback). Set 0 to disable the LLM call.
#VEDIC_DIGEST_LLM=1

# ── Depth features: per-action credit costs (v1.21) ─────────────────────────
# Varshaphala year reading / grounded remedies / prashna are one LLM reading
# each; the in-depth two-chart compatibility report is priced higher.
#VEDIC_CREDIT_COST_VARSHAPHALA=25
#VEDIC_CREDIT_COST_REMEDIES=25
#VEDIC_CREDIT_COST_COMPATIBILITY=75
#VEDIC_CREDIT_COST_PRASHNA=25

# ── Monetization amplifiers (v1.22) ─────────────────────────────────────────
# Premium tiered PDF: the 20+ page chaptered life report generated asynchronously
# (basic tier keeps VEDIC_CREDIT_COST_PDF). Finished PDFs are written under
# VEDIC_REPORTS_DIR (gitignored) with unguessable names.
#VEDIC_CREDIT_COST_PDF_PREMIUM=150
#VEDIC_REPORTS_DIR=/path/to/reports
# Signed, session-less premium-report links (WhatsApp delivery): HMAC secret and
# link lifetime. The secret defaults to the persisted operator API key.
#VEDIC_REPORT_SIGNING_SECRET=change_me_to_a_long_random_string
#VEDIC_REPORT_LINK_TTL_HOURS=72

# Gift a reading: whether a purchaser may redeem their OWN code (0 = forbidden),
# and the fixed GST-inclusive price (paise) of the premium-report voucher.
#VEDIC_GIFT_SELF_REDEEM=0
#VEDIC_GIFT_PDF_VOUCHER_PRICE_PAISE=24900

# ── WhatsApp Business Cloud API (Meta) delivery ─────────────────────────────
# Fails closed like Razorpay: with WHATSAPP_ENABLED=0 (default) nothing is sent.
# Token + phone-number id come from the Meta app; the webhook verify token is
# echoed on the GET subscription handshake; the webhook secret verifies the
# X-Hub-Signature-256 HMAC on inbound events (delivery status + STOP opt-out).
#WHATSAPP_ENABLED=0
#WHATSAPP_TOKEN=your_meta_cloud_api_token
#WHATSAPP_PHONE_ID=your_whatsapp_phone_number_id
#WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token
#WHATSAPP_WEBHOOK_SECRET=your_app_secret_for_signature_verification
# Pre-approved template names, one per language (report_ready_* / daily_digest_*).
#WHATSAPP_TEMPLATE_REPORT_READY_EN=report_ready_en
#WHATSAPP_TEMPLATE_REPORT_READY_TA=report_ready_ta
#WHATSAPP_TEMPLATE_REPORT_READY_TE=report_ready_te
#WHATSAPP_TEMPLATE_REPORT_READY_ML=report_ready_ml
#WHATSAPP_TEMPLATE_REPORT_READY_KN=report_ready_kn
#WHATSAPP_TEMPLATE_REPORT_READY_HI=report_ready_hi
#WHATSAPP_TEMPLATE_DIGEST_EN=daily_digest_en
#WHATSAPP_TEMPLATE_DIGEST_TA=daily_digest_ta
#WHATSAPP_TEMPLATE_DIGEST_TE=daily_digest_te
#WHATSAPP_TEMPLATE_DIGEST_ML=daily_digest_ml
#WHATSAPP_TEMPLATE_DIGEST_KN=daily_digest_kn
#WHATSAPP_TEMPLATE_DIGEST_HI=daily_digest_hi
