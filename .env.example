# ─────────────────────────────────────────────────────────────────────────────
# Vedic Astrology RAG Portal — environment variable reference
#
# Copy to `.env` and fill in as needed:   cp .env.example .env
# Every value is OPTIONAL; the defaults shown work for a local single-host setup.
#
# IMPORTANT: the app reads from the *process environment* — it does NOT auto-load
# this file. Load it before launching, e.g.:
#     set -a && source .env && set +a && python3 app.py
# or, for systemd, point the unit at it:   EnvironmentFile=/path/to/.env
# `.env` is gitignored; this `.env.example` is the committed template.
# ─────────────────────────────────────────────────────────────────────────────

# ── Paths ────────────────────────────────────────────────────────────────────
# SQLite database (defaults to ./vedic_astrology_rag.db next to app.py).
#VEDIC_DB_PATH=/home/prasanth/Vedic_Rag/vedic_astrology_rag.db
# Folder holding the source PDF books for OCR ingest / page-image rendering
# (defaults to ./books next to app.py).
#VEDIC_BOOKS_DIR=/path/to/vedic_astrology_books
# Worker threads for the OCR ingest job (defaults to the host CPU count).
#VEDIC_INGEST_THREADS=4
# Log verbosity: DEBUG / INFO / WARNING / ERROR (default INFO).
#VEDIC_LOG_LEVEL=INFO

# ── Ollama backend ───────────────────────────────────────────────────────────
#OLLAMA_HOST=http://localhost:11434

# ── Models ───────────────────────────────────────────────────────────────────
#VEDIC_EMBED_MODEL=nomic-embed-text
#VEDIC_EMBED_DIM=768
#VEDIC_LLM_MODEL=gemma4:31b-cloud

# ── Timeouts (seconds) ───────────────────────────────────────────────────────
#VEDIC_EMBED_TIMEOUT=15
#VEDIC_LLM_TIMEOUT=300

# ── API key (gates every /api/* except the open auth/health paths) ───────────
# If unset, a key is auto-generated and saved to `.api_key` (printed once to the
# console on first run). Set this to pin a stable key across machines.
#VEDIC_API_KEY=replace-with-a-long-random-secret

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins, or "*" (default). Set to your real front-end
# origin in production; credentials turn on automatically once it isn't "*".
#VEDIC_CORS_ORIGINS=https://astro.example.com

# ── Credit / billing ─────────────────────────────────────────────────────────
# Emails (comma-separated, case-insensitive) that bypass credit metering.
#VEDIC_UNLIMITED_EMAILS=admin@example.com
# Real payments are not wired up. Set a Stripe key to integrate (then implement
# it), or enable the local-dev simulation. Leave both unset to disable billing.
#STRIPE_SECRET_KEY=sk_live_xxx
#VEDIC_ALLOW_SIMULATED_PAYMENTS=0

# ── OAuth / social login ─────────────────────────────────────────────────────
# Identity is taken only from a provider-verified token; unconfigured providers
# fail closed. Set these to enable real Google / Facebook sign-in.
#GOOGLE_OAUTH_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
#FACEBOOK_APP_ID=xxxxxxxx
#FACEBOOK_APP_SECRET=xxxxxxxx
# Dev-only: trust the supplied email (cannot take over password/other-provider
# accounts). NEVER enable in production.
#VEDIC_ALLOW_MOCK_OAUTH=0
